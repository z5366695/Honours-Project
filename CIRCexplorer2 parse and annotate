PARAMS=(SCZD+CNTRL)

. /srv/scratch/DIR/miniconda/bin/activate
 
cd /srv/scratch/DIR/STAR_alignment/${PARAMS[$PBS_ARRAY_INDEX]}
 
CIRCexplorer2 parse -t STAR /srv/scratch/DIR/STAR_alignment/${PARAMS[$PBS_ARRAY_INDEX]}_StarChimeric.out.junction > ${PARAMS[$PBS_ARRAY_INDEX]}_parse.log


