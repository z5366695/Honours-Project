#!/bin/bash
#PBS -N CE_parse
#PBS -l ncpus=1
#PBS -l mem=40gb
#PBS -l walltime=11:59:00 
#PBS -j oe
#PBS -M zID@unsw.edu.au 
#PBS -m ae
