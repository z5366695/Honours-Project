brain_genes = read.csv(file="permuted_all_combined.txt", header = FALSE)

brain <- as.vector(brain_genes$V1)
list.brain <- bitr(brain,
                   fromType = 'SYMBOL',
                   toType = 'ENTREZID',
                   OrgDb = 'org.Hs.eg.db')

brain_genes_pathway <- enrichGO(list.brain$SYMBOL,keyType="SYMBOL",
                                OrgDb = org.Hs.eg.db,
                                ont = 'BP',
                                pAdjustMethod = 'BH',
                                pvalueCutoff = 0.01,
                                qvalueCutoff = 0.5)
head(brain_genes_pathway)
barplot(brain_genes_pathway, drop=TRUE, showCategory = 20, font.size = 5)
dotplot(brain_genes_pathway, showCategory = 20, font.size = 5)
brain_genes_pathway2 <- pairwise_termsim(brain_genes_pathway)
