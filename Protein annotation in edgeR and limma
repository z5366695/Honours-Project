#!/usr/bin/env Rscript
args = commandArgs(trailingOnly=TRUE)
setwd("/srv/scratch/DIR/all_merge_wavg")

if(length(args) < 1){
  stop("Need sample ID")
}

sampleID <- args[1]
common_files   <- paste0("common_circ_", sampleID, "_withAvg.txt")
cat("Reading:", common_files, "\n")
CF   <- read.csv(common_files, sep="\t", header=TRUE)
common <- merge(common_files, by="circRNA_ID")

write.table(common, file=paste0("combined_all_merged.txt"), sep="\t", quote=F, row.names = FALSE)

