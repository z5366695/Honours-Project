###Kegg enrichment

genes <- read.table("permuted_all_combined.txt", header = FALSE, stringsAsFactors = FALSE)[[1]]

# Map SYMBOLs to ENTREZIDs
gene.df <- bitr(genes,
                fromType = "SYMBOL",
                toType = "ENTREZID",
                OrgDb = org.Hs.eg.db)

entrez_genes <- gene.df$ENTREZID
kegg_results <- enrichKEGG(gene         = entrez_genes,
                           organism     = 'hsa',
                           pvalueCutoff = 0.5)
dotplot(kegg_results, showCategory = 10)
kegg_results <- pairwise_termsim(kegg_results)

emapplot(kegg_results, showCategory = 10)
