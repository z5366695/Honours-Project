# Make a DGElist 
x <- readDGE(files, columns=c(1, 29), row.names(FALSE)) 
# reading col(1) since it has the genomic coordinates, col(29) has the average circRNA count - check which column is avg

# Define group as factor (sczd or control) 
group <- as.factor(c(rep('SCZD', 170),                      rep('Control', 356))) 
group

# add group information to DGElist
x$samples$group <- group

# reading library sizes
lib_sizes <- readLines("libsize.txt") #libsize.txt has the unique alignment reads sequence numbers (from STAR alignment)
lib_sizes <- as.numeric(lib_sizes)
x$samples$lib.size <- lib_sizes

# filtering - check against potential issue - code functioned afterwards
x_filtered$samples$lib.size

# filtering out lowly expressed reads
dx_keep <- rowSums(cpm(x)>0.1) >=2

# new DGElist with highly expressed reads
dx_filtered <- x[dx_keep,]

# Normalisation 
dx_filtered <- calcNormFactors(dx_filtered, method="TMM")
design <- model.matrix(~0+group)
colnames(design) <- gsub("group", "", colnames(design))
design
