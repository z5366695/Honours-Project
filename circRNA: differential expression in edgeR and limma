# Set up differential expression
contr.matrix <- makeContrasts(
  AvsB = SCZD - Control,
  levels = colnames(design))

# Linear fit to model
v <- voom(x_filtered, design)
vfit <- lmFit(v, design)
vfit <- contrasts.fit(vfit, contrasts=contr.matrix)

# Bayesian statistics
efit <- eBayes(vfit)

# Shows which genes are differentially expressed
summary(decideTests(efit))

# Make a list of top hits
AvsB <- topTable(efit, coef = 1, n=Inf)

# make a list of those significantly differentially expressed
AvsBsignificant <- AvsB[AvsB$adj.P.Val < 0.1, ]

# write output to file
write.table(AvsB, file="./SCZDvsCNTRL_AvsB.txt", sep = "\t")
write.table(AvsBsignificant, file="./SCZDvsCNTRL_SIG_AvsB.txt", sep = "\t")
write.table(x$counts, file="./SCZDvsCNTRL_AvsB_counts.txt", sep = "\t")

